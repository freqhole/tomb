  "query": "SELECT\n            p.id as \"id!\",\n            p.title as \"title!\",\n            p.description,\n            p.is_public as \"is_public!\",\n            p.thumbnail_blob_id,\n            p.created_by_id,\n            p.created_at as \"created_at!\",\n            p.updated_at as \"updated_at!\",\n            p.deleted_at,\n            p.deleted_by,\n            p.created_by,\n            p.updated_by,\n            COALESCE(COUNT(ps.song_id), 0) as \"song_count!: i64\"\n        FROM playlistz p\n        LEFT JOIN playlist_songz ps ON p.id = ps.playlist_id\n        WHERE p.id = ?\n        GROUP BY p.id",
