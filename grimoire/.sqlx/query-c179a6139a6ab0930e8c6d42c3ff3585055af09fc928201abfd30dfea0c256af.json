  "query": "SELECT\n            id as \"id!\",\n            media_blob_id as \"media_blob_id!\",\n            thumbnail_blob_id,\n            waveform_blob_id,\n            title as \"title!\",\n            track_number as \"track_number!\",\n            disc_number as \"disc_number!\",\n            duration,\n            year,\n            bpm,\n            key_signature,\n            metadata,\n            lyrics,\n            processing_status,\n            processing_notes,\n            created_at as \"created_at!\",\n            updated_at as \"updated_at!\",\n            deleted_at,\n            deleted_by,\n            created_by,\n            updated_by\n         FROM songz\n         WHERE deleted_at IS NULL\n         ORDER BY created_at DESC\n         LIMIT ? OFFSET ?",
