  "query": "SELECT\n            rowid as \"rowid!\",\n            id as \"id!\",\n            media_blob_id as \"media_blob_id!\",\n            thumbnail_blob_id,\n            waveform_blob_id,\n            title as \"title!\",\n            artist,\n            album,\n            album_artist,\n            track_number,\n            disc_number,\n            duration,\n            year,\n            bpm,\n            key_signature,\n            rating,\n            is_favorite,\n            tags,\n            metadata,\n            processing_status,\n            processing_notes,\n            sub_genres,\n            created_at as \"created_at!\",\n            updated_at as \"updated_at!\",\n            deleted_at,\n            deleted_by,\n            created_by,\n            updated_by\n         FROM songz\n         WHERE deleted_at IS NULL\n         ORDER BY created_at DESC\n         LIMIT 100",
