// WebAuthn Server Test Configuration
//
// This configuration is used specifically for integration tests
// It uses the test database on port 5433 and test-specific settings
//
{
  "app": {
    "name": "WebAuthn Demo Test",
    "version": "1.0.0",
    "environment": "test",
    "description": "WebAuthn authentication server for testing"
  },
  "database": {
    "host": "localhost",
    "port": 5433,
    "name": "test_db",
    "user": "postgres",
    "pool": {
      "max_connections": 5,
      "min_connections": 1,
      "connect_timeout_seconds": 10,
      "idle_timeout_seconds": 300
    },
    "migrations": {
      "auto_run": true
    }
  },
  "webauthn": {
    "rp_id": "localhost",
    "rp_name": "WebAuthn Test",
    "rp_origin": "http://localhost:8080"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "sessions": {
    "max_age_seconds": 1800,
    "secure": false,
    "same_site": "strict",
    "http_only": true
  },

  "logging": {
    "level": "debug"
  },
  "analytics": {
    "metrics": {
      "enabled": false,
      "prometheus_endpoint": "/metrics",
      "health_endpoint": "/health"
    }
  },
  "static_files": {
    "public_directory": "assets/public",
    "private_directory": "assets/private",
    "assets_directory": "assets"
  },
  "storage": {
    "analytics": "postgres",
    "sessions": "postgres"
  },
  "media": {
    "max_blob_file_size": 10485760,
    "max_fs_file_size": 1073741824
  },
  "notifications": {
    "channels": {},
    "rate_limiting": {
      "enabled": true,
      "global_events_per_minute": 10000,
      "per_channel_events_per_minute": 5000,
      "per_user_events_per_minute": 100,
      "time_window_seconds": 60,
      "overflow_strategy": "Drop",
      "apply_to_high_priority": false
    },
    "postgres": {
      "enabled": false,
      "listener_connections": 1,
      "listen_timeout_seconds": 10,
      "reconnect_interval_seconds": 2,
      "max_reconnect_attempts": 3,
      "notification_buffer_size": 100
    },
    "websocket": {
      "enabled": false,
      "max_connections": 100,
      "heartbeat_interval_seconds": 10,
      "connection_timeout_seconds": 30,
      "max_message_size_bytes": 65536,
      "per_connection_buffer_size": 10
    },
    "queue": {
      "enable_persistence": false,
      "max_queue_size": 1000,
      "cleanup_interval_seconds": 60,
      "max_event_age_seconds": 3600,
      "max_retry_attempts": 1,
      "retry_backoff": "Fixed",
      "dead_letter_queue": false
    },
    "general": {
      "enable_debug_logging": true,
      "default_delivery_timeout_seconds": 1,
      "enable_metrics": false,
      "metrics_interval_seconds": 30,
      "health_check_interval_seconds": 15,
      "max_concurrent_processors": 10
    }
  },
  "development": {
    "auto_generate_invites": true
  },

  "features": {
    "registration_enabled": true,
    "invite_codes_required": true,
    "analytics_enabled": false
  }
}
