---
import { Icon } from "@astrojs/starlight/components";
import { VERSION } from "../version";

// download picker with platform/arch detection.
// asset filenames must match tomb/Makefile output names. version is baked
// at build time from src/version.ts (kept in sync by `make bump-version`).

interface Props {
  heroOnly?: boolean;
  buttonOnly?: boolean;
}
const { heroOnly = false, buttonOnly = false } = Astro.props;

const REPO = "freqhole/tomb";
const BASE = `https://github.com/${REPO}/releases/download/${VERSION}`;

const ASSETS: Record<string, string> = {
  "charnel-mac-arm": `freqhole_charnel_${VERSION}_aarch64.dmg`,
  "charnel-mac-intel": `freqhole_charnel_${VERSION}_x86_64.dmg`,
  "charnel-linux-x86-flatpak": `freqhole_charnel_${VERSION}_x86_64.flatpak`,
  "charnel-linux-x86-deb": `freqhole_charnel_${VERSION}_x86_64.deb`,
  "charnel-linux-x86-rpm": `freqhole_charnel_${VERSION}_x86_64.rpm`,
  "charnel-linux-arm-flatpak": `freqhole_charnel_${VERSION}_aarch64.flatpak`,
  "charnel-linux-arm-deb": `freqhole_charnel_${VERSION}_aarch64.deb`,
  "charnel-linux-arm-rpm": `freqhole_charnel_${VERSION}_aarch64.rpm`,
  "charnel-android": `freqhole_charnel_${VERSION}_android-universal.apk`,
  "charnel-android-arm64": `freqhole_charnel_${VERSION}_android-arm64.apk`,
  "cli-mac-arm": `rathole_${VERSION}_darwin-aarch64`,
  "cli-mac-intel": `rathole_${VERSION}_darwin-x86_64`,
  "cli-linux-x86": `rathole_${VERSION}_linux-x86_64`,
  "cli-linux-arm64": `rathole_${VERSION}_linux-aarch64`,
  "cli-linux-armv7": `rathole_${VERSION}_linux-armv7`,
};

const url = (key: string) => `${BASE}/${ASSETS[key]}`;
const urlsJson = JSON.stringify(
  Object.fromEntries(Object.keys(ASSETS).map((k) => [k, url(k)])),
);
---

<div data-dl-picker data-version={VERSION} data-dl-urls={urlsJson} class:list={["dl-picker", "not-content", { "dl-button-only": buttonOnly }]}>
  {!buttonOnly && (
  <div class="dl-hero" data-dl-hero>
    <div class="dl-hero-icon" data-dl-hero-icon aria-hidden="true">
      <span class="dl-icon-slot" data-icon-slot="apple"><Icon name="apple" size="3rem" /></span>
      <span class="dl-icon-slot" data-icon-slot="linux" hidden><Icon name="linux" size="3rem" /></span>
      <span class="dl-icon-slot" data-icon-slot="laptop" hidden><Icon name="laptop" size="3rem" /></span>
      <span class="dl-icon-slot" data-icon-slot="cloud" hidden><Icon name="cloud" size="3rem" /></span>
    </div>
    <div class="dl-hero-body">
      <div class="dl-hero-eyebrow" data-dl-hero-eyebrow>detected platform</div>
      <h2 class="dl-hero-title" data-dl-hero-title>charnel desktop app</h2>
      <p class="dl-hero-sub" data-dl-hero-sub>the recommended freqhole experience</p>
      <a
        class="dl-hero-button"
        data-dl-hero-button
        href="https://github.com/freqhole/tomb/releases/latest"
        rel="noopener"
      >
        <span class="dl-hero-button-label" data-dl-hero-button-label>download charnel</span>
        <span class="dl-hero-button-meta" data-dl-hero-button-meta></span>
      </a>
      <a
        class="dl-hero-secondary"
        data-dl-hero-secondary
        href="https://spume.freqhole.net"
        rel="noopener"
        hidden
      >
        prefer the web app? goto spume.freqhole.net <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
  )}

  {buttonOnly && (
    <a
      class="dl-hero-button dl-button-standalone"
      data-dl-hero-button
      href="https://github.com/freqhole/tomb/releases/latest"
      rel="noopener"
    >
      <span class="dl-hero-button-label" data-dl-hero-button-label>download charnel</span>
      <span class="dl-hero-button-meta" data-dl-hero-button-meta></span>
    </a>
  )}

  {!buttonOnly && !heroOnly && (
  <div class="dl-more" data-dl-more>
    <div class="dl-brainstorm-note" data-dl-brainstorm-note hidden>
      <span class="dl-brainstorm-note-text">highlighted below are the builds matching your <a href="/getting-started/brainstorm/">brainstorm</a> picks.</span>
      <button type="button" class="dl-brainstorm-reset" data-dl-brainstorm-reset>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
        <span>reset</span>
      </button>
    </div>
    <div class="dl-brainstorm-help" data-dl-brainstorm-help>
      <span class="dl-brainstorm-help-text">having trouble figuring out which file to download? get help on the <a href="/getting-started/brainstorm/">brainstorm</a> page.</span>
    </div>
    <h2 class="dl-more-title">all releases</h2>
    <h3 class="dl-section-title">
      <span class="dl-section-icon"><Icon name="laptop" size="1.1rem" /></span>
      charnel <small>(gui app)</small>
    </h3>

    <div class="dl-platform-grid">
      <section class="dl-plat">
        <h4><span class="dl-plat-icon"><Icon name="apple" size="1.1rem" /></span> macOS</h4>
        <div class="dl-arch-row">
          <div class="dl-arch">
            <div class="dl-arch-label">apple silicon</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-mac-arm" href={url("charnel-mac-arm")}>.dmg</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">intel</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-mac-intel" href={url("charnel-mac-intel")}>.dmg</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="dl-plat">
        <h4><span class="dl-plat-icon"><Icon name="linux" size="1.1rem" /></span> linux</h4>
        <div class="dl-arch-row">
          <div class="dl-arch">
            <div class="dl-arch-label">x86_64</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-linux-x86-flatpak" href={url("charnel-linux-x86-flatpak")}>.flatpak</a></li>
              <li><a data-dl="charnel-linux-x86-deb" href={url("charnel-linux-x86-deb")}>.deb</a></li>
              <li><a data-dl="charnel-linux-x86-rpm" href={url("charnel-linux-x86-rpm")}>.rpm</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">aarch64 (raspberry pi 4+)</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-linux-arm-flatpak" href={url("charnel-linux-arm-flatpak")}>.flatpak</a></li>
              <li><a data-dl="charnel-linux-arm-deb" href={url("charnel-linux-arm-deb")}>.deb</a></li>
              <li><a data-dl="charnel-linux-arm-rpm" href={url("charnel-linux-arm-rpm")}>.rpm</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="dl-plat">
        <h4><span class="dl-plat-icon"><Icon name="laptop" size="1.1rem" /></span> android</h4>
        <div class="dl-arch-row">
          <div class="dl-arch">
            <div class="dl-arch-label">universal</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-android" href={url("charnel-android")}>.apk</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">arm64</div>
            <ul class="dl-list">
              <li><a data-dl="charnel-android-arm64" href={url("charnel-android-arm64")}>.apk</a></li>
            </ul>
          </div>
        </div>
      </section>
    </div>

    <h3 class="dl-section-title">
      <span class="dl-section-icon"><Icon name="seti:powershell" size="1.1rem" /></span>
      rathole <small>(tui binary)</small>
    </h3>

    <div class="dl-platform-grid">
      <section class="dl-plat">
        <h4><span class="dl-plat-icon"><Icon name="apple" size="1.1rem" /></span> macOS</h4>
        <div class="dl-arch-row">
          <div class="dl-arch">
            <div class="dl-arch-label">apple silicon</div>
            <ul class="dl-list">
              <li><a data-dl="cli-mac-arm" href={url("cli-mac-arm")}>aarch64-apple-darwin</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">intel</div>
            <ul class="dl-list">
              <li><a data-dl="cli-mac-intel" href={url("cli-mac-intel")}>x86_64-apple-darwin</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="dl-plat">
        <h4><span class="dl-plat-icon"><Icon name="linux" size="1.1rem" /></span> linux</h4>
        <div class="dl-arch-row">
          <div class="dl-arch">
            <div class="dl-arch-label">x86_64</div>
            <ul class="dl-list">
              <li><a data-dl="cli-linux-x86" href={url("cli-linux-x86")}>x86_64-unknown-linux-gnu</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">aarch64 (raspberry pi 4+)</div>
            <ul class="dl-list">
              <li><a data-dl="cli-linux-arm64" href={url("cli-linux-arm64")}>aarch64-unknown-linux-gnu</a></li>
            </ul>
          </div>
          <div class="dl-arch">
            <div class="dl-arch-label">armv7 (raspi armv7)</div>
            <ul class="dl-list">
              <li><a data-dl="cli-linux-armv7" href={url("cli-linux-armv7")}>armv7-unknown-linux-gnueabihf</a></li>
            </ul>
          </div>
        </div>
      </section>
    </div>

    <h3 class="dl-section-title" data-dl-web-section>
      <span class="dl-section-icon"><Icon name="cloud" size="1.1rem" /></span>
      web
    </h3>
    <ul class="dl-list dl-web-list">
      <li><a href="https://spume.freqhole.net" rel="noopener" data-dl="web-spume">spume.freqhole.net</a> — hosted web app</li>
      <li>self-hosted: bundled with the server, available at <code>http://your-server:8080</code></li>
    </ul>

    <p class="dl-foot">
      see all assets on <a href="https://github.com/freqhole/tomb/releases/latest" rel="noopener">github releases</a>. using a different platform? you might be able to build it from the source code: <a href="https://github.com/freqhole/tomb/" rel="noopener">/freqhole/tomb/ on github</a>
    </p>
  </div>
  )}
</div>

<script>
  (() => {
    const root = document.querySelector("[data-dl-picker]");
    if (!root) return;

    const REPO = "freqhole/tomb";
    const FALLBACK_RELEASES = `https://github.com/${REPO}/releases/latest`;
    const SPUME_URL = "https://spume.freqhole.net";

    function detect() {
      const ua = navigator.userAgent || "";
      const uaData = /** @type {any} */ (navigator).userAgentData;

      let os = "unknown";
      let arch = "unknown";

      if (uaData?.platform) {
        const p = uaData.platform.toLowerCase();
        if (p.includes("mac")) os = "mac";
        else if (p.includes("windows")) os = "windows";
        else if (p.includes("linux")) os = "linux";
        else if (p.includes("android")) os = "android";
      }
      if (os === "unknown") {
        if (/android/i.test(ua)) os = "android";
        else if (/iphone|ipad|ipod/i.test(ua)) os = "ios";
        else if (/mac os x|macintosh/i.test(ua)) os = "mac";
        else if (/windows/i.test(ua)) os = "windows";
        else if (/linux/i.test(ua)) os = "linux";
      }

      if (/aarch64|arm64/i.test(ua)) arch = "arm64";
      else if (/armv7|armhf/i.test(ua)) arch = "armv7";
      else if (/x86_64|x64|win64|wow64|amd64/i.test(ua)) arch = "x86_64";
      else if (/i[3-6]86|x86/i.test(ua)) arch = "x86";

      if (os === "mac" && arch === "unknown") {
        arch = /intel mac/i.test(ua) ? "x86_64" : "arm64";
      }
      if (os === "windows" && arch === "unknown") arch = "x86_64";

      if (uaData?.getHighEntropyValues) {
        uaData
          .getHighEntropyValues(["architecture", "bitness"])
          .then((v) => {
            const a = (v.architecture || "").toLowerCase();
            const b = v.bitness || "";
            if (a === "arm" && b === "64") refine("arm64");
            else if (a === "arm") refine("armv7");
            else if (a === "x86" && b === "64") refine("x86_64");
            else if (a === "x86") refine("x86");
          })
          .catch(() => {});
      }

      return { os, arch };
    }

    /** @type {{os:string, arch:string}} */
    let detected = detect();

    function refine(newArch) {
      if (newArch !== detected.arch) {
        detected = { ...detected, arch: newArch };
        renderHero();
      }
    }

    function pickHero({ os, arch }) {
      if (os === "windows" || os === "ios" || os === "unknown") {
        return {
          kind: "web",
          icon: os === "windows" ? "laptop" : "cloud",
          label: os === "windows" ? "windows" : os === "ios" ? "iOS" : "your browser",
          buttonLabel: "open web app",
          sub: "freqhole runs in your browser via spume",
          href: SPUME_URL,
          meta: "spume.freqhole.net",
        };
      }
      if (os === "mac") {
        const isArm = arch === "arm64" || arch === "unknown";
        return {
          kind: "charnel",
          icon: "apple",
          label: isArm ? "macOS · apple silicon" : "macOS · intel",
          buttonLabel: "download mac app",
          sub: "desktop app — recommended",
          assetKey: isArm ? "charnel-mac-arm" : "charnel-mac-intel",
          ext: ".dmg",
        };
      }
      if (os === "linux") {
        const isArm = arch === "arm64";
        return {
          kind: "charnel",
          icon: "linux",
          label: isArm ? "linux · aarch64" : "linux · x86_64",
          buttonLabel: "download linux app",
          sub: "flatpak bundle — also available as .deb / .rpm below",
          assetKey: isArm ? "charnel-linux-arm-flatpak" : "charnel-linux-x86-flatpak",
          ext: ".flatpak",
        };
      }
      if (os === "android") {
        return {
          kind: "charnel",
          icon: "laptop",
          label: "android",
          buttonLabel: "download apk",
          sub: "universal release apk",
          assetKey: "charnel-android",
          ext: ".apk",
        };
      }
      return null;
    }

    const version = root.getAttribute("data-version") || "";

    // build a key -> url map by reading the baked anchors rendered by astro,
    // falling back to the JSON map baked into data-dl-urls (needed in buttonOnly mode
    // where the per-asset anchors aren't rendered).
    /** @type {Record<string, string>} */
    let urls = {};
    try {
      const raw = root.getAttribute("data-dl-urls");
      if (raw) urls = JSON.parse(raw);
    } catch {}
    root.querySelectorAll("a[data-dl]").forEach((a) => {
      const key = a.getAttribute("data-dl");
      if (key) urls[key] = /** @type {HTMLAnchorElement} */ (a).href;
    });

    function showIcon(name) {
      root.querySelectorAll("[data-icon-slot]").forEach((el) => {
        el.toggleAttribute("hidden", el.getAttribute("data-icon-slot") !== name);
      });
    }

    function renderHero() {
      const pick = pickHero(detected);
      const eyebrow = root.querySelector("[data-dl-hero-eyebrow]");
      const title = root.querySelector("[data-dl-hero-title]");
      const sub = root.querySelector("[data-dl-hero-sub]");
      const btn = /** @type {HTMLAnchorElement} */ (root.querySelector("[data-dl-hero-button]"));
      const btnLabel = root.querySelector("[data-dl-hero-button-label]");
      const btnMeta = root.querySelector("[data-dl-hero-button-meta]");
      const secondary = /** @type {HTMLAnchorElement} */ (root.querySelector("[data-dl-hero-secondary]"));

      if (!pick) return;

      showIcon(pick.icon);
      if (eyebrow) eyebrow.textContent = `detected: ${pick.label}`;
      if (title) title.textContent = pick.kind === "web" ? "use the web app" : "desktop app";
      if (sub) sub.textContent = pick.sub;
      if (btnLabel) btnLabel.textContent = pick.buttonLabel;

      if (pick.kind === "web") {
        if (btn) btn.href = pick.href;
        if (btnMeta) btnMeta.textContent = pick.meta || "";
        if (secondary) secondary.hidden = true;
      } else {
        const u = urls[pick.assetKey];
        if (btn) btn.href = u || FALLBACK_RELEASES;
        if (btnMeta) btnMeta.textContent = version ? `v${version} · ${pick.ext}` : pick.ext;
        if (secondary) secondary.hidden = false;
      }
    }

    renderHero();

    // ---- brainstorm highlights ---------------------------------------------
    // read the selections saved by the brainstorm page (same localStorage key)
    // and highlight the matching builds in the "all releases" grid: selected
    // pills + their platform sections get an accent; everything else is muted.
    const BRAINSTORM_KEY = "freqhole-brainstorm-v1";
    const moreEl = root.querySelector("[data-dl-more]");
    const bsNote = root.querySelector("[data-dl-brainstorm-note]");
    const bsHelp = root.querySelector("[data-dl-brainstorm-help]");
    const bsReset = root.querySelector("[data-dl-brainstorm-reset]");

    function readBrainstorm() {
      try {
        const raw = localStorage.getItem(BRAINSTORM_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    }

    // the brainstorm flow records the exact files it wants as asset keys in
    // state.files; those are the data-dl values to highlight here.
    function highlightedKeys(state) {
      return new Set(Array.isArray(state.files) ? state.files : []);
    }

    function applyHighlights() {
      const state = readBrainstorm();
      const keys = state ? highlightedKeys(state) : new Set();
      const active = keys.size > 0;

      if (moreEl) moreEl.classList.toggle("dl-more--brainstorm", active);
      if (bsNote) bsNote.toggleAttribute("hidden", !active);
      // the help prompt is the inverse: show it only when no brainstorm
      // picks are active, so the page always offers a route to figuring
      // out which file to grab.
      if (bsHelp) bsHelp.toggleAttribute("hidden", active);

      // pills
      root.querySelectorAll("a[data-dl]").forEach((a) => {
        const key = a.getAttribute("data-dl");
        const on = active && key && keys.has(key);
        a.classList.toggle("dl-pick", !!on);
        a.classList.toggle("dl-muted", active && !on);
      });

      // platform sections (highlight if they contain a picked pill)
      root.querySelectorAll(".dl-plat").forEach((sec) => {
        const has = active && !!sec.querySelector("a.dl-pick");
        sec.classList.toggle("dl-plat--pick", has);
        sec.classList.toggle("dl-plat--muted", active && !has);
      });

      // web section header
      const webHead = root.querySelector("[data-dl-web-section]");
      if (webHead) {
        const has = active && !!root.querySelector('a[data-dl="web-spume"].dl-pick');
        webHead.classList.toggle("dl-section--pick", has);
        webHead.classList.toggle("dl-section--muted", active && !has);
      }

      syncBrainstormToc(active);
    }

    // add/remove an "all releases" entry in the starlight "on this page"
    // sidebar so the brainstorm-highlighted container is reachable from the toc.
    function syncBrainstormToc(show) {
      if (moreEl && !moreEl.id) moreEl.id = "all-releases";
      const tocLists = document.querySelectorAll("starlight-toc nav > ul, mobile-starlight-toc nav ul");
      tocLists.forEach((list) => {
        const existing = list.querySelector("[data-brainstorm-toc]");
        if (show && !existing && moreEl) {
          const li = document.createElement("li");
          li.setAttribute("data-brainstorm-toc", "");
          const first = list.querySelector("li");
          if (first) li.className = first.className;
          const a = document.createElement("a");
          a.href = `#${moreEl.id}`;
          a.textContent = "your picks";
          const tmpl = first?.querySelector("a");
          if (tmpl) a.className = tmpl.className;
          li.appendChild(a);
          list.insertBefore(li, list.firstChild);
        } else if (!show && existing) {
          existing.remove();
        }
      });
    }

    if (bsReset) {
      bsReset.addEventListener("click", () => {
        try {
          localStorage.removeItem(BRAINSTORM_KEY);
        } catch {}
        applyHighlights();
      });
    }

    applyHighlights();
  })();
</script>

<style>
  .dl-picker {
    margin: 1.5rem 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* brainstorm-driven highlighting of the "all releases" container */
  .dl-more--brainstorm {
    padding: 1.25rem 1.4rem 1.5rem;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent, #d63384) 45%, transparent);
    background:
      radial-gradient(120% 120% at 0% 0%, color-mix(in srgb, var(--sl-color-accent-low, #2a1622) 45%, transparent), transparent 65%),
      var(--sl-color-gray-7, #0f0f0f);
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--sl-color-accent, #d63384) 30%, transparent) inset,
      0 14px 36px -14px color-mix(in srgb, var(--sl-color-accent, #d63384) 45%, transparent);
  }
  .dl-brainstorm-note {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid color-mix(in srgb, var(--sl-color-accent, #d63384) 30%, var(--sl-color-gray-6, #1a1a1a));
  }
  .dl-brainstorm-note[hidden] { display: none; }
  .dl-brainstorm-note-text { font-size: 0.85rem; color: var(--sl-color-gray-2, #ccc); }
  .dl-brainstorm-help {
    margin-bottom: 0.9rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--sl-color-gray-6, #1a1a1a);
  }
  .dl-brainstorm-help[hidden] { display: none; }
  .dl-brainstorm-help-text { font-size: 0.85rem; color: var(--sl-color-gray-3, #999); }
  .dl-brainstorm-reset {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    padding: 0.3rem 0.6rem;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5, #2a2a2a);
    background: var(--sl-color-gray-6, #1a1a1a);
    color: var(--sl-color-gray-2, #ccc);
    cursor: pointer;
    flex: none;
  }
  .dl-brainstorm-reset:hover { color: var(--sl-color-white, #fff); border-color: var(--sl-color-accent, #d63384); }

  /* picked platform sections get an accent border + subtle lift */
  .dl-plat--pick {
    border-color: color-mix(in srgb, var(--sl-color-accent, #d63384) 55%, var(--sl-color-gray-5, #2a2a2a));
