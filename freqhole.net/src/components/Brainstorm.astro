---
// interactive "brainstorm" widget for the freqhole docs.
//
// a stateful, multi-stage flow that helps a new user think through their setup
// before they start: what hardware do you have, where does your music live,
// how do you want to share, and how to manage the library. vanilla TS state
// machine + d3 for the two svg visuals (the hardware flow diagram and the
// device-connection graph). all selections persist to a single localStorage
// key; a reset button appears when state exists.
//
// styles are global (namespaced under .brainstorm) because d3-created
// elements don't receive astro's scoped-style attribute.
---

<div class="brainstorm not-content" data-brainstorm>
  <noscript>
    <div class="sw-noscript">
      this walkthrough needs javascript. here are the same steps as plain
      links:
      <ul>
        <li><a href="/getting-started/download/">download a build</a></li>
        <li><a href="/getting-started/prerequisites/">prerequisites (ffmpeg, yt-dlp)</a></li>
        <li><a href="/guides/scanning/">scanning your library</a></li>
        <li><a href="/guides/sharing/">sharing with friends</a></li>
        <li><a href="/guides/metadata-enrichment/">metadata enrichment</a></li>
        <li><a href="/concepts/transports/">HTTP vs P2P</a></li>
      </ul>
    </div>
  </noscript>

  <header class="sw-head">
    <div class="sw-head-title">brainstorm your setup</div>
    <button type="button" class="sw-reset" data-sw-reset hidden>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
      <span>reset</span>
    </button>
  </header>

  <div class="sw-sections" data-sw-sections></div>
</div>

<style is:global>
  .brainstorm {
    --sw-edge: var(--sl-color-gray-4, #9ca3af);
    --sw-card-bg: var(--sl-color-gray-6, #1b1b25);
    --sw-card-border: var(--sl-color-gray-5, #2b2b3a);
    margin: 1.5rem 0 2.5rem;
    border: 1px solid var(--sw-card-border);
    border-radius: 14px;
    background:
      radial-gradient(120% 120% at 0% 0%, color-mix(in srgb, var(--sl-color-accent-low) 22%, transparent), transparent 60%),
      var(--sl-color-black, #0b0b10);
    overflow: hidden;
  }

  .sw-noscript {
    padding: 1rem 1.25rem;
    color: var(--sl-color-gray-2);
  }

  .sw-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--sw-card-border);
    flex-wrap: wrap;
    position: sticky;
    top: var(--sl-nav-height, 0);
    z-index: 5;
    background: var(--sl-color-black, #0b0b10);
  }
  .sw-head-title { font-size: 0.95rem; font-weight: 600; color: var(--sl-color-white); }

  /* vertically-stacked sections */
  .sw-sections { display: flex; flex-direction: column; }
  .sw-section {
    padding: 1.4rem 1.25rem;
    border-bottom: 1px solid var(--sw-card-border);
    scroll-margin-top: calc(var(--sl-nav-height, 0px) + 3.5rem);
  }
  .sw-section:last-child { border-bottom: none; }
  .sw-section-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
  }
  .sw-section-num {
    flex: none;
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: var(--sl-color-accent);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .sw-reset {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    padding: 0.3rem 0.6rem;
    border-radius: 8px;
    border: 1px solid var(--sw-card-border);
    background: var(--sw-card-bg);
    color: var(--sl-color-gray-2);
    cursor: pointer;
  }
  .sw-reset:hover { color: var(--sl-color-white); border-color: var(--sl-color-accent); }

  .sw-stage-title { margin: 0; font-size: 1.35rem; line-height: 1.2; }
  .sw-stage-sub { margin: 0 0 1.1rem; color: var(--sl-color-gray-2); font-size: 0.95rem; }
  .sw-q-label { font-size: 0.92rem; color: var(--sl-color-gray-2); margin: 1.1rem 0 0.5rem; }

  /* chips (multi-select) */
  .sw-chips { display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .sw-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    border-radius: 10px;
    border: 1px solid var(--sw-card-border);
    background: var(--sw-card-bg);
    color: var(--sl-color-gray-1);
    cursor: pointer;
    font-size: 0.92rem;
    transition: all 0.14s ease;
  }
  .sw-chip:hover { border-color: var(--sl-color-accent); transform: translateY(-1px); }
  .sw-chip[aria-pressed="true"] {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sw-card-bg));
    color: var(--sl-color-white);
    box-shadow: 0 0 0 1px var(--sl-color-accent) inset;
  }
  .sw-chip svg { flex: none; }
  .sw-chip .sw-chip-ico { width: 1.25rem; height: 1.25rem; display: grid; place-items: center; color: var(--sl-color-accent-high); }

  /* hardware flow svg */
  .sw-flow-wrap { width: 100%; overflow-x: auto; margin: 0.5rem 0 0.25rem; }
  .sw-flow { display: block; }
  .sw-flow .sw-node rect {
    fill: var(--sw-card-bg);
    stroke: var(--sw-card-border);
    stroke-width: 1.5;
    transition: fill 0.15s ease, stroke 0.15s ease;
    cursor: pointer;
  }
  .sw-flow .sw-node:hover rect { stroke: var(--sl-color-accent); }
  .sw-flow .sw-node[data-on="1"] rect {
    fill: color-mix(in srgb, var(--sl-color-accent) 20%, var(--sw-card-bg));
    stroke: var(--sl-color-accent);
  }
  /* leaf nodes are real download files - dashed outline + accent text */
  .sw-flow .sw-node[data-leaf="1"] rect { stroke-dasharray: 4 3; }
  .sw-flow .sw-node[data-leaf="1"][data-on="1"] rect {
    fill: color-mix(in srgb, var(--sl-color-accent) 32%, var(--sw-card-bg));
    stroke-dasharray: none;
  }
  .sw-flow .sw-node text { fill: var(--sl-color-gray-1); font-size: 13px; pointer-events: none; }
  .sw-flow .sw-node[data-on="1"] text { fill: var(--sl-color-white); }
  .sw-flow .sw-node-sub { fill: var(--sl-color-gray-3); font-size: 10px; }
  .sw-flow .sw-node[data-on="1"] .sw-node-sub { fill: var(--sl-color-accent-high); }
  /* default icon is near-white for contrast on the dark card; the accent tint
     is kept for hover + selected, where the accent border/fill frames it. */
  .sw-flow .sw-node .sw-node-ico { color: var(--sl-color-gray-1); pointer-events: none; transition: color 0.15s ease; }
  .sw-flow .sw-node:hover .sw-node-ico,
  .sw-flow .sw-node[data-on="1"] .sw-node-ico { color: var(--sl-color-accent-high); }
  .sw-flow .sw-col-title { fill: var(--sl-color-gray-3); font-size: 11px; text-transform: lowercase; letter-spacing: 0.04em; }
  .sw-flow .sw-link { fill: none; stroke: var(--sw-edge); stroke-width: 1.5; opacity: 0.35; }
  .sw-flow .sw-link[data-on="1"] { stroke: var(--sl-color-accent); opacity: 0.9; stroke-width: 2; }

  /* result / guidance cards */
  .sw-cards { display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); margin-top: 0.75rem; }
  .sw-card {
    border: 1px solid var(--sw-card-border);
    border-radius: 12px;
    background: var(--sw-card-bg);
    padding: 0.85rem 0.95rem;
  }
  .sw-card h4 { margin: 0 0 0.35rem; font-size: 0.98rem; display: flex; align-items: center; gap: 0.45rem; }
  .sw-card h4 .sw-card-ico { color: var(--sl-color-accent-high); width: 1.2rem; height: 1.2rem; display: grid; place-items: center; }
  .sw-card p { margin: 0 0 0.5rem; font-size: 0.86rem; color: var(--sl-color-gray-2); }
  .sw-card .sw-card-link {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.85rem; font-weight: 600; color: var(--sl-color-accent-high); text-decoration: none;
  }
  .sw-card .sw-card-link:hover { text-decoration: underline; }
  .sw-card[data-variant="web"] { border-color: color-mix(in srgb, var(--sl-color-accent) 45%, var(--sw-card-border)); }
  .sw-card-badge {
    display: inline-block; font-size: 0.68rem; padding: 0.1rem 0.4rem; border-radius: 6px;
    background: color-mix(in srgb, var(--sl-color-accent) 25%, transparent); color: var(--sl-color-accent-high);
    margin-left: 0.4rem; vertical-align: middle;
  }

  .sw-empty { color: var(--sl-color-gray-3); font-size: 0.9rem; font-style: italic; padding: 0.5rem 0; }

  /* device graph svg */
  .sw-graph-wrap { width: 100%; margin-top: 0.5rem; border: 1px solid var(--sw-card-border); border-radius: 12px; background: var(--sw-card-bg); overflow: hidden; }
  .sw-graph { display: block; width: 100%; height: 440px; touch-action: none; }
  /* the graph sits gently muted; hovering a node brings it + its neighbors to
     full color while the rest dims back. */
  .sw-graph .sw-g-node { filter: saturate(0.7) brightness(0.92); transition: opacity 0.15s ease, filter 0.15s ease; }
  .sw-graph .sw-g-node.hot { filter: none; }
  .sw-graph .sw-g-node.dim { opacity: 0.22; filter: saturate(0.4) brightness(0.7); }
  .sw-graph .sw-g-node .sw-g-shape { stroke-width: 4; cursor: grab; }
  .sw-graph .sw-g-node text { fill: var(--sl-color-gray-1); font-size: 11px; text-anchor: middle; pointer-events: none; }
  .sw-graph .sw-g-node .sw-g-label-bg {
    fill: color-mix(in srgb, var(--sl-color-black, #0b0b10) 78%, transparent);
    stroke: var(--sw-card-border);
    stroke-width: 1;
    pointer-events: none;
  }
  .sw-graph .sw-g-node .sw-g-ico { color: #fff; pointer-events: none; filter: drop-shadow(0 1px 1px rgba(0,0,0,0.45)); }
  .sw-graph .sw-g-link { stroke-width: 2.5; opacity: 0.5; fill: none; filter: saturate(0.7); transition: opacity 0.15s ease, filter 0.15s ease; }
  .sw-graph .sw-g-link.hot { opacity: 0.95; filter: none; stroke-width: 3; }
  .sw-graph .sw-g-link.dim { opacity: 0.08; }
  .sw-graph .sw-g-link.http { stroke-dasharray: 6 4; }
  .sw-graph .sw-g-link.relay { stroke-dasharray: 2 5; stroke-linecap: round; }
  .sw-graph .sw-g-link.mesh { stroke: var(--sl-color-gray-3); opacity: 0.12; stroke-width: 1.5; }
  .sw-graph .sw-g-link.mesh.hot { opacity: 0.3; stroke-width: 1.5; }
  .sw-graph .sw-g-link.mesh.dim { opacity: 0.05; }
  .sw-legend { display: flex; gap: 0.7rem 1.1rem; flex-wrap: wrap; align-items: center; padding: 0.6rem 0.85rem; border-top: 1px solid var(--sw-card-border); font-size: 0.8rem; color: var(--sl-color-gray-2); }
  .sw-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .sw-legend .sw-legend-sep { width: 1px; height: 0.95rem; background: var(--sw-card-border); }
  .sw-legend i { width: 1.4rem; height: 0; border-top-width: 3px; border-top-style: solid; display: inline-block; }
  .sw-legend i.p2p { border-top-color: var(--sl-color-gray-2); }
  .sw-legend i.http { border-top-color: var(--sl-color-gray-2); border-top-style: dashed; }
  .sw-legend i.relay { border-top-color: var(--sl-color-gray-2); border-top-style: dotted; }
  .sw-legend i.ring { width: 0.82rem; height: 0.82rem; border: 3px solid; border-radius: 50%; background: transparent; box-sizing: border-box; }
  .sw-legend i.ring.you { border-color: var(--sl-color-accent); }
  .sw-legend i.ring.family { border-color: #22c55e; }
  .sw-legend i.ring.friend { border-color: #38bdf8; }

  @media (max-width: 560px) {
    .sw-section { padding: 1.1rem 0.85rem; }
  }
</style>

<script>
  import * as d3 from "d3";

  // ---- icons (inner svg, 0 0 24 24 viewBox, currentColor) -----------------
  const ICONS: Record<string, string> = {
    desktop: `<rect x="4" y="5" width="16" height="10" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M2 19h20M9 19l.5-2h5l.5 2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
    mobile: `<rect x="7" y="3" width="10" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M11 18h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`,
    raspi: `<g fill="currentColor"><path d="M12 10.6C10.5 8 7.5 7 5.6 7.6 7 9.8 9.8 11 12 10.6ZM12 10.6C13.5 8 16.5 7 18.4 7.6 17 9.8 14.2 11 12 10.6Z"/><circle cx="8.3" cy="13.8" r="2.4"/><circle cx="12" cy="13.8" r="2.4"/><circle cx="15.7" cy="13.8" r="2.4"/><circle cx="10.1" cy="17.3" r="2.4"/><circle cx="13.9" cy="17.3" r="2.4"/><circle cx="12" cy="20.6" r="2.4"/></g>`,
    apple: `<path fill="currentColor" d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701z"/>`,
    windows: `<path fill="currentColor" d="M3 5.6 10.4 4.6v6.8H3zM11.6 4.45 21 3.1v8.3h-9.4zM3 12.6h7.4v6.8L3 18.4zM11.6 12.6H21v8.3l-9.4-1.35z"/>`,
    linux: `<path fill="currentColor" d="M12 2c-1.9 0-3.1 1.5-3.1 3.5 0 .8.2 1.4.2 2-.6.6-1.9 2.3-2.5 4.4-.5 1.7-1.1 2.7-1.7 3.4-.5.6-.2 1.5.7 1.6.5.1.7.4.7.9 0 .9.9 1.8 2.9 1.8h5.6c2 0 2.9-.9 2.9-1.8 0-.5.2-.8.7-.9.9-.1 1.2-1 .7-1.6-.6-.7-1.2-1.7-1.7-3.4-.6-2.1-1.9-3.8-2.5-4.4 0-.6.2-1.2.2-2C15.1 3.5 13.9 2 12 2z"/><ellipse cx="10.2" cy="6.2" rx=".9" ry="1.1" fill="#6b7280"/><ellipse cx="13.8" cy="6.2" rx=".9" ry="1.1" fill="#6b7280"/><path d="M10.8 8.6 12 9.6l1.2-1c-.4-.5-2-.5-2.4 0z" fill="#f59e0b"/>`,
    android: `<g fill="currentColor"><path d="M6.2 9.2h11.6v6.6a1.4 1.4 0 0 1-1.4 1.4H7.6a1.4 1.4 0 0 1-1.4-1.4z"/><rect x="3.3" y="9.6" width="1.9" height="5.4" rx=".95"/><rect x="18.8" y="9.6" width="1.9" height="5.4" rx=".95"/><rect x="8.4" y="16.6" width="1.9" height="4.2" rx=".95"/><rect x="13.7" y="16.6" width="1.9" height="4.2" rx=".95"/><path d="M6.2 8.4a5.8 5.8 0 0 1 11.6 0z"/></g><path d="M7.8 3.6 9.1 5.5M16.2 3.6 14.9 5.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="9.5" cy="6.2" r=".6" fill="#6b7280"/><circle cx="14.5" cy="6.2" r=".6" fill="#6b7280"/>`,
    gui: `<rect x="3" y="4" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M3 9h18" stroke="currentColor" stroke-width="1.7"/><circle cx="6" cy="6.5" r=".6" fill="currentColor"/><circle cx="8" cy="6.5" r=".6" fill="currentColor"/>`,
    cli: `<rect x="3" y="4" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M7 9l3 3-3 3M13 15h4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>`,
    chip: `<rect x="7" y="7" width="10" height="10" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M10 4v3M14 4v3M10 17v3M14 17v3M4 10h3M4 14h3M17 10h3M17 14h3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
    download: `<path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
    web: `<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" fill="none" stroke="currentColor" stroke-width="1.8"/>`,
    music: `<path d="M9 18V5l10-2v13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="18" r="3" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="16" cy="16" r="3" fill="none" stroke="currentColor" stroke-width="1.8"/>`,
    link: `<path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>`,
    qr: `<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4z" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M14 14h3v3M20 14v6M14 20h6" fill="none" stroke="currentColor" stroke-width="1.7"/>`,
    share: `<circle cx="6" cy="12" r="2.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="18" cy="6" r="2.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="18" cy="18" r="2.5" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8.2 10.8 15.8 7.2M8.2 13.2 15.8 16.8" stroke="currentColor" stroke-width="1.8"/>`,
    edit: `<path d="M4 20h4l10-10-4-4L4 16z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M13 6l4 4" stroke="currentColor" stroke-width="1.8"/>`,
    table: `<rect x="3" y="4" width="18" height="16" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M3 9h18M3 14h18M9 9v11" stroke="currentColor" stroke-width="1.7"/>`,
    server: `<rect x="3" y="4" width="18" height="6" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="14" width="18" height="6" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="7" cy="7" r=".9" fill="currentColor"/><circle cx="7" cy="17" r=".9" fill="currentColor"/>`,
    friend: `<circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M4 21c0-4 3.6-6 8-6s8 2 8 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>`,
    sparkle: `<path d="M12 3l2 5 5 2-5 2-2 5-2-5-5-2 5-2z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
    eyes: `<ellipse cx="6.4" cy="12" rx="5.4" ry="7.6" fill="none" stroke="currentColor" stroke-width="1.6"/><ellipse cx="17.6" cy="12" rx="5.4" ry="7.6" fill="none" stroke="currentColor" stroke-width="1.6"/><ellipse cx="8.1" cy="13.3" rx="3.9" ry="2.7" fill="currentColor"/><ellipse cx="18.9" cy="13.3" rx="3.9" ry="2.7" fill="currentColor"/><circle cx="8.7" cy="13.9" r="0.9" fill="var(--sw-card-bg)"/><circle cx="19.5" cy="13.9" r="0.9" fill="var(--sw-card-bg)"/>`,
  };

  function svgIcon(name: string, size = 20): string {
    return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" aria-hidden="true">${ICONS[name] || ""}</svg>`;
  }

  // ---- state --------------------------------------------------------------
  const KEY = "freqhole-brainstorm-v1";
  type State = {
    picks: string[];   // selected flow node ids (path-scoped, e.g. "mac/gui/arm")
    files: string[];   // derived asset keys for the leaf nodes (consumed by the download page)
    music: string[];   // local, url
    library: string[]; // dirs, addmusic, enrich
  };
  // always hand back fresh arrays. a shared const with array fields would get
  // mutated in place by the toggle/push helpers, which poisons the "empty"
  // baseline and makes reset fail to return to a clean slate.
  function freshState(): State {
    return { picks: [], files: [], music: [], library: [] };
  }

  function load(): State {
    const base = freshState();
    try {
      const raw = localStorage.getItem(KEY);
      if (!raw) return base;
      const p = JSON.parse(raw);
      if (!p || typeof p !== "object") return base;
      return {
        picks: Array.isArray(p.picks) ? p.picks.slice() : base.picks,
        files: Array.isArray(p.files) ? p.files.slice() : base.files,
        music: Array.isArray(p.music) ? p.music.slice() : base.music,
        library: Array.isArray(p.library) ? p.library.slice() : base.library,
      };
    } catch { return freshState(); }
  }
  let state = load();
  let hasStored = !!localStorage.getItem(KEY);
  let updateReset = () => {};

  function save() {
    try { localStorage.setItem(KEY, JSON.stringify(state)); hasStored = true; } catch { /* ignore */ }
    updateReset();
  }
  function toggle(arr: string[], v: string) {
    const i = arr.indexOf(v);
    if (i >= 0) arr.splice(i, 1); else arr.push(v);
  }

  // ---- dom refs -----------------------------------------------------------
  // init runs at the very bottom of this script, after every const (CARDS,
  // flowSpec, etc.) is initialized. calling it here would hit the temporal
  // dead zone for those later declarations when the render path touches them.
  const root = document.querySelector<HTMLElement>("[data-brainstorm]");

  function init(root: HTMLElement) {
    const sectionsEl = root.querySelector<HTMLElement>("[data-sw-sections]")!;
    const resetBtn = root.querySelector<HTMLButtonElement>("[data-sw-reset]")!;

    const STAGES = [
      { key: "hardware", label: "hardware", render: renderHardware },
      { key: "music", label: "music", render: renderMusic },
      { key: "sharing", label: "sharing", render: renderSharing },
      { key: "library", label: "library", render: renderLibrary },
    ];

    updateReset = () => { resetBtn.hidden = !hasStored; };

    function paint() {
      sectionsEl.innerHTML = "";
      STAGES.forEach((s, i) => {
        const section = document.createElement("section");
        section.className = "sw-section";
        section.id = `brainstorm-${s.key}`;
        section.dataset.num = String(i + 1);
        s.render(section);
        sectionsEl.appendChild(section);
      });
      updateReset();
    }

    resetBtn.addEventListener("click", () => {
      localStorage.removeItem(KEY);
      hasStored = false;
      state = freshState();
      paint();
    });

    paint();
    syncBrainstormToc();
  }

  // add numbered entries for the four stages to starlight's "on this page"
  // sidebar so each section is reachable from the table of contents.
  function syncBrainstormToc() {
    const entries = [
      { id: "brainstorm-hardware", text: "1. hardware" },
      { id: "brainstorm-music", text: "2. music" },
      { id: "brainstorm-sharing", text: "3. sharing" },
      { id: "brainstorm-library", text: "4. library" },
    ];
    const lists = document.querySelectorAll("starlight-toc nav > ul, mobile-starlight-toc nav ul");
    lists.forEach((list) => {
      if (list.querySelector("[data-brainstorm-toc]")) return;
      const first = list.querySelector("li");
      const tmplA = first?.querySelector("a");
      entries.forEach((e) => {
        const li = document.createElement("li");
        li.setAttribute("data-brainstorm-toc", "");
        if (first) li.className = first.className;
        const a = document.createElement("a");
        a.href = `#${e.id}`;
        a.textContent = e.text;
        if (tmplA) a.className = tmplA.className;
        li.appendChild(a);
        list.appendChild(li);
      });
    });
  }

  // ---- helpers for chip rows ---------------------------------------------
  function chipRow(
    container: HTMLElement,
    arr: string[],
    opts: { id: string; label: string; icon?: string }[],
    onChange: () => void,
  ) {
    const row = document.createElement("div");
    row.className = "sw-chips";
    opts.forEach((o) => {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "sw-chip";
      b.setAttribute("aria-pressed", String(arr.includes(o.id)));
      b.innerHTML = `${o.icon ? `<span class="sw-chip-ico">${svgIcon(o.icon)}</span>` : ""}<span>${o.label}</span>`;
      b.addEventListener("click", () => {
        toggle(arr, o.id);
        b.setAttribute("aria-pressed", String(arr.includes(o.id)));
        save();
        onChange();
      });
      row.appendChild(b);
    });
    container.appendChild(row);
  }

  function label(container: HTMLElement, text: string) {
    const d = document.createElement("div");
    d.className = "sw-q-label";
    d.textContent = text;
    container.appendChild(d);
  }
  function stageHeader(container: HTMLElement, title: string, sub: string) {
    const num = container.closest<HTMLElement>(".sw-section")?.dataset.num || "";
    const head = document.createElement("div");
    head.className = "sw-section-head";
    if (num) {
      const numEl = document.createElement("div");
      numEl.className = "sw-section-num";
      numEl.textContent = num;
      head.appendChild(numEl);
    }
    const body = document.createElement("div");
    const h = document.createElement("h3");
    h.className = "sw-stage-title";
    h.textContent = title;
    body.appendChild(h);
    head.appendChild(body);
    const s = document.createElement("p");
    s.className = "sw-stage-sub";
    s.textContent = sub;
    container.appendChild(head);
    container.appendChild(s);
  }

  type Card = { variant?: string; icon: string; title: string; badge?: string; body: string; link?: { href: string; text: string } };
  function cardGrid(container: HTMLElement, cards: Card[]) {
    if (!cards.length) {
      const e = document.createElement("div");
      e.className = "sw-empty";
      e.textContent = "make a selection above to see suggestions.";
      container.appendChild(e);
      return;
    }
    const grid = document.createElement("div");
    grid.className = "sw-cards";
    cards.forEach((c) => {
      const el = document.createElement("div");
      el.className = "sw-card";
      if (c.variant) el.dataset.variant = c.variant;
      el.innerHTML = `
        <h4><span class="sw-card-ico">${svgIcon(c.icon)}</span>${c.title}${c.badge ? `<span class="sw-card-badge">${c.badge}</span>` : ""}</h4>
        <p>${c.body}</p>
        ${c.link ? `<a class="sw-card-link" href="${c.link.href}">${svgIcon("link", 14)} ${c.link.text}</a>` : ""}`;
      grid.appendChild(el);
    });
    container.appendChild(grid);
  }

  // ===== stage 1: hardware =================================================
  // the hardware flow is a tree. each device fans out into its own platform,
  // interface, cpu and package branches, and every branch ends in a leaf node
  // that maps to a real download file. branches are independent: picking arm64
  // for mac doesn't touch the cpu choice for linux or android. selections are
  // stored as path-scoped node ids in state.picks; the leaf asset keys are
  // mirrored into state.files for the download page to highlight.
  type Leaf = { key: string; ext: string };
  type FNode = { id: string; label: string; sub?: string; icon?: string; leaf?: Leaf; kids?: FNode[] };

  const DL = "/getting-started/download/";
  const SPUME = "https://spume.freqhole.net";

  function flowSpec(): FNode[] {
