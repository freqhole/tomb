      { id: "desktop", label: "desktop", sub: "/ laptop", icon: "desktop", kids: [
        { id: "mac", label: "macOS", icon: "apple", kids: [
          { id: "mac/gui", label: "gui app", sub: "charnel", icon: "gui", kids: [
