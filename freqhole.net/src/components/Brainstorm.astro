  // download-card metadata, keyed by leaf asset key. multiple leaves can share
  // a key (e.g. windows + iphone both end at the web app), so cards are deduped.
  const CARDS: Record<string, Card> = {
    "charnel-mac-arm": { icon: "download", title: "charnel for macOS", badge: "gui", body: "the desktop app, .dmg for apple silicon.", link: { href: DL, text: "download charnel" } },
    "charnel-mac-intel": { icon: "download", title: "charnel for macOS", badge: "gui", body: "the desktop app, .dmg for intel macs.", link: { href: DL, text: "download charnel" } },
    "cli-mac-arm": { icon: "cli", title: "rathole for macOS", badge: "cli", body: "the tui/server binary for apple silicon.", link: { href: DL, text: "download rathole" } },
    "cli-mac-intel": { icon: "cli", title: "rathole for macOS", badge: "cli", body: "the tui/server binary for intel macs.", link: { href: DL, text: "download rathole" } },
    "charnel-linux-x86-deb": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as a .deb (debian / ubuntu), x86_64.", link: { href: DL, text: "download charnel" } },
    "charnel-linux-x86-rpm": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as an .rpm (fedora / red hat), x86_64.", link: { href: DL, text: "download charnel" } },
    "charnel-linux-x86-flatpak": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as a .flatpak, x86_64.", link: { href: DL, text: "download charnel" } },
    "charnel-linux-arm-deb": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as a .deb (debian / ubuntu), aarch64.", link: { href: DL, text: "download charnel" } },
    "charnel-linux-arm-rpm": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as an .rpm (fedora / red hat), aarch64.", link: { href: DL, text: "download charnel" } },
    "charnel-linux-arm-flatpak": { icon: "download", title: "charnel for linux", badge: "gui", body: "desktop app as a .flatpak, aarch64 (works on a raspberry pi desktop).", link: { href: DL, text: "download charnel" } },
    "cli-linux-x86": { icon: "cli", title: "rathole for linux", badge: "cli", body: "server/tui binary, x86_64.", link: { href: DL, text: "download rathole" } },
    "cli-linux-arm64": { icon: "cli", title: "rathole for linux", badge: "cli", body: "server/tui binary, aarch64 (pi 4+ and other arm64 boards).", link: { href: DL, text: "download rathole" } },
    "cli-linux-armv7": { icon: "cli", title: "rathole for linux", badge: "cli", body: "server/tui binary, armv7 (older raspberry pis).", link: { href: DL, text: "download rathole" } },
    "charnel-android-arm64": { icon: "android", title: "charnel for android", badge: "apk", body: "the android app, arm64 .apk (the default for most phones).", link: { href: DL, text: "download apk" } },
    "charnel-android": { icon: "android", title: "charnel for android", badge: "apk", body: "the android app, universal .apk (any cpu).", link: { href: DL, text: "download apk" } },
    "web-spume": { variant: "web", icon: "web", title: "spume web app", badge: "web", body: "use the hosted web app, or self-host it.", link: { href: SPUME, text: "open spume.freqhole.net" } },
  };

  // walk the tree, collecting the leaf asset keys for every selected leaf.
  function collectFiles(picks: Set<string>): string[] {
    const out: string[] = [];
    const seen = new Set<string>();
    const walk = (nodes: FNode[]) => nodes.forEach((n) => {
      if (n.leaf && picks.has(n.id) && !seen.has(n.leaf.key)) { seen.add(n.leaf.key); out.push(n.leaf.key); }
      if (n.kids) walk(n.kids);
    });
    walk(flowSpec());
    return out;
  }
  function syncFiles() { state.files = collectFiles(new Set(state.picks)); }

  function renderHardware(c: HTMLElement) {
    stageHeader(c, "what hardware do you have?", "click a device, then follow the branches down to the exact files you need. pick as many as you like.");
    drawFlow(c);

    const sug = document.createElement("div");
    sug.style.marginTop = "1rem";
    label(sug, "your downloads");
    cardGrid(sug, buildSuggestions());
    c.appendChild(sug);
  }

  function rerender(c: HTMLElement) { c.innerHTML = ""; renderHardware(c); }

  function drawFlow(c: HTMLElement) {
    const spec = flowSpec();
    const picks = new Set(state.picks);

    const NW = 150, NH = 54, COLGAP = 64, ROWGAP = 14, PADX = 12, PADY = 12;

    // tree layout: leaves take sequential rows, parents center on their kids.
    const pos = new Map<string, { x: number; y: number }>();
    const placed: { node: FNode; x: number; y: number; depth: number }[] = [];
    let row = 0, maxDepth = 0;

    function place(node: FNode, depth: number): number {
      maxDepth = Math.max(maxDepth, depth);
      const selected = picks.has(node.id);
      const kids = selected && node.kids ? node.kids : [];
      let y: number;
      if (!kids.length) {
        y = PADY + row * (NH + ROWGAP);
        row++;
      } else {
        const ys = kids.map((k) => place(k, depth + 1));
        y = (ys[0] + ys[ys.length - 1]) / 2;
      }
      const x = PADX + depth * (NW + COLGAP);
      pos.set(node.id, { x, y });
      placed.push({ node, x, y, depth });
      return y;
    }
    spec.forEach((r) => place(r, 0));

    const height = PADY * 2 + Math.max(1, row) * (NH + ROWGAP) - ROWGAP;
    const width = PADX * 2 + (maxDepth + 1) * NW + maxDepth * COLGAP;

    const wrap = document.createElement("div");
    wrap.className = "sw-flow-wrap";
    c.appendChild(wrap);

    const svg = d3.select(wrap).append("svg")
      .attr("class", "sw-flow")
      .attr("viewBox", `0 0 ${width} ${height}`)
      .attr("width", width)
      .attr("height", height)
      .style("max-width", "100%");

    // edges from each selected node to its (now visible) children
    const links: { x1: number; y1: number; x2: number; y2: number; on: boolean }[] = [];
    placed.forEach(({ node, x, y }) => {
      if (!picks.has(node.id) || !node.kids) return;
      const p = pos.get(node.id)!;
      node.kids.forEach((k) => {
        const cp = pos.get(k.id);
        if (!cp) return;
        links.push({ x1: p.x + NW, y1: y + NH / 2, x2: cp.x, y2: cp.y + NH / 2, on: picks.has(k.id) });
      });
    });

    svg.append("g").selectAll("path").data(links.sort((a) => (a.on ? 1 : -1))).join("path")
      .attr("class", "sw-link")
      .attr("data-on", (d) => (d.on ? "1" : "0"))
      .attr("d", (d) => {
        const mx = (d.x1 + d.x2) / 2;
        return `M${d.x1},${d.y1} C${mx},${d.y1} ${mx},${d.y2} ${d.x2},${d.y2}`;
      });

    placed.forEach(({ node, x, y }) => {
      const on = picks.has(node.id);
      const g = svg.append("g")
        .attr("class", "sw-node")
        .attr("data-on", on ? "1" : "0")
        .attr("data-leaf", node.leaf ? "1" : "0")
        .attr("transform", `translate(${x},${y})`)
        .style("cursor", "pointer")
        .on("click", () => {
          if (picks.has(node.id)) {
            // deselect this node and any of its descendant branches
            state.picks = state.picks.filter((p) => p !== node.id && !p.startsWith(node.id + "/"));
          } else {
            state.picks.push(node.id);
            // selecting android pre-picks the arm64 .apk (the common default)
            if (node.id === "android" && !state.picks.includes("android/arm64")) {
              state.picks.push("android/arm64");
            }
          }
          syncFiles();
          save();
          rerender(c);
        });
      g.append("rect").attr("width", NW).attr("height", NH).attr("rx", 10);
      g.append("g").attr("class", "sw-node-ico")
        .attr("transform", `translate(12,${NH / 2 - 12})`)
        .html(node.icon && ICONS[node.icon] ? `<svg width="24" height="24" viewBox="0 0 24 24">${ICONS[node.icon]}</svg>` : "");
      if (node.sub) {
        g.append("text").attr("x", 46).attr("y", NH / 2 - 1).text(node.label);
        g.append("text").attr("class", "sw-node-sub").attr("x", 46).attr("y", NH / 2 + 14).text(node.sub);
      } else {
        g.append("text").attr("x", 46).attr("y", NH / 2 + 4).text(node.label);
      }
    });
  }

  function buildSuggestions(): Card[] {
    return (state.files || []).map((k) => CARDS[k]).filter(Boolean);
  }

  // ===== stage 2: music sources ===========================================
  function renderMusic(c: HTMLElement) {
    stageHeader(c, "where's your music coming from?", "freqhole can import audio you already have, or fetch it from urls with yt-dlp.");
    label(c, "music sources (multi-select)");
    chipRow(c, state.music, [
      { id: "local", label: "local audio files", icon: "music" },
      { id: "url", label: "urls (yt-dlp)", icon: "link" },
    ], () => { save(); renderMusicCards(); });

    const holder = document.createElement("div");
    holder.style.marginTop = "1rem";
    c.appendChild(holder);

    function renderMusicCards() {
      holder.innerHTML = "";
      const cards: Card[] = [];
      if (state.music.includes("local")) {
        cards.push({ icon: "music", title: "scan local files",
          body: "point freqhole at folders of mp3, flac, m4a, ogg, opus, wav and more. it imports tags + builds your catalog without touching the originals.",
          link: { href: "/guides/scanning/", text: "initial scan + add music" } });
      }
      if (state.music.includes("url")) {
        cards.push({ icon: "link", title: "fetch from urls",
          body: "give freqhole a url that yt-dlp understands and it downloads + imports the audio. install yt-dlp first.",
          link: { href: "/getting-started/prerequisites/", text: "set up yt-dlp" } });
      }
      cardGrid(holder, cards);
    }
    renderMusicCards();
  }

  // ===== stage 3: sharing ==================================================
  function renderSharing(c: HTMLElement) {
    stageHeader(c, "share across your devices", "connect your phone, laptop, and friends to your library. freqhole has peer-to-peer networking so you don't need a public ip or port forwarding.");

    const steps = document.createElement("div");
    steps.className = "sw-cards";
    const phoneFirst = state.picks.includes("mobile") || state.picks.includes("android");
    const cards: Card[] = [
      { icon: "qr", title: phoneFirst ? "start with your phone" : "pair a device",
        body: "open the app on another device and scan your server's node id qr code (or paste the node id). download music and listen offline.",
        link: { href: "/guides/sharing/", text: "sharing with friends" } },
      { icon: "share", title: "p2p by default", badge: "recommended",
        body: "peer-to-peer connects devices directly by node id. encrypted, nat-friendly, no dns or ssl certificates to manage; but you can use http, and self-host everything if you want.",
        link: { href: "/concepts/transports/", text: "how transports work" } },
    ];
    cards.forEach((cd) => {
      const el = document.createElement("div");
      el.className = "sw-card";
      if (cd.badge) el.dataset.variant = "web";
      el.innerHTML = `
        <h4><span class="sw-card-ico">${svgIcon(cd.icon)}</span>${cd.title}${cd.badge ? `<span class="sw-card-badge">${cd.badge}</span>` : ""}</h4>
        <p>${cd.body}</p>
        <a class="sw-card-link" href="${cd.link!.href}">${svgIcon("link", 14)} ${cd.link!.text}</a>`;
      steps.appendChild(el);
    });
    c.appendChild(steps);

    label(c, "an example freqhole network with you and yr frenz");
    drawDeviceGraph(c);
  }

  function drawDeviceGraph(c: HTMLElement) {
    type Group = "you" | "family" | "friend";
    type GNode = { id: string; label: string; icon: string; group: Group; person: string; server?: boolean; fx?: number; fy?: number; x?: number; y?: number };
    type GLink = { source: string; target: string; kind: "p2p" | "http" | "relay" | "mesh" };

    const accent = getComputedStyle(document.documentElement).getPropertyValue("--sl-color-accent").trim() || "#c026d3";
    // the ring around each node shows how you know them (you / family / friend)
    const GROUP: Record<Group, string> = { you: accent, family: "#22c55e", friend: "#38bdf8" };
    // the fill of each node is a unique per-person color so individuals stand out
    const PERSON_COLOR: Record<string, string> = {
      you: "#2dd4bf", nancy: "#fb7185", fritzi: "#a78bfa", sluggo: "#ec4899",
      rollo: "#f472b6", butch: "#facc15", irma: "#fb923c", oona: "#c084fc", phil: "#f87171",
    };

    // the four freqhole-mark vertices, centered on the node origin. used to give
    // server nodes the wonky triangle silhouette instead of a plain circle.
    function freqholePoints(r: number): string {
      const frac: ReadonlyArray<readonly [number, number]> = [
        [0.5, 0.95], [0.14, 0.18], [0.86, 0.18], [0.66, 0.74],
      ];
      const cfx = 0.54, cfy = 0.5125; // centroid of the four vertices
      return frac.map(([fx, fy]) => `${((fx - cfx) * 2 * r).toFixed(1)},${((fy - cfy) * 2 * r).toFixed(1)}`).join(" ");
    }

    // three servers — yours, a family member's (nancy), and a friend's (sluggo).
    // each server hosts its own devices plus guest accounts for friends + family.
    // people aren't tied to one host: several guests have accounts on more than
    // one server.
    const nodes: GNode[] = [
      // your stuff
      { id: "srv-you", label: "your raspi", icon: "server", group: "you", person: "you", server: true },
      { id: "you-phone", label: "your iphone", icon: "mobile", group: "you", person: "you" },
      { id: "you-laptop", label: "your laptop (cli)", icon: "desktop", group: "you", person: "you" },
      { id: "fritzi", label: "fritzi", icon: "friend", group: "family", person: "fritzi" },
      // nancy — a family member running her own server (two devices)
      { id: "srv-nancy", label: "nancy's pc", icon: "server", group: "family", person: "nancy", server: true },
      { id: "nancy-android", label: "nancy's android", icon: "mobile", group: "family", person: "nancy" },
      { id: "nancy-web", label: "nancy's web browser", icon: "web", group: "family", person: "nancy" },
      { id: "rollo", label: "rollo", icon: "friend", group: "friend", person: "rollo" },
      { id: "butch", label: "butch", icon: "friend", group: "friend", person: "butch" },
      // sluggo — a friend running his own server (two devices)
      { id: "srv-sluggo", label: "sluggo's raspi", icon: "server", group: "friend", person: "sluggo", server: true },
      { id: "sluggo-phone", label: "sluggo's tablet", icon: "mobile", group: "friend", person: "sluggo" },
      { id: "sluggo-laptop", label: "sluggo's laptop", icon: "desktop", group: "friend", person: "sluggo" },
      { id: "irma", label: "irma", icon: "friend", group: "friend", person: "irma" },
      { id: "oona", label: "oona goosepimple", icon: "friend", group: "friend", person: "oona" },
      { id: "phil", label: "phil fumble", icon: "friend", group: "friend", person: "phil" },
    ];
    const links: GLink[] = [
      { source: "fritzi", target: "srv-you", kind: "p2p" },
      // nancy's own devices + the friends she hosts. phones + web apps go over
      // the p2p http relay; laptops connect direct p2p.
      // nancy's android connects direct p2p to all three servers it has accounts on
      { source: "nancy-android", target: "srv-nancy", kind: "p2p" },
      { source: "nancy-android", target: "srv-you", kind: "p2p" },
      { source: "nancy-android", target: "srv-sluggo", kind: "p2p" },
      { source: "nancy-web", target: "srv-nancy", kind: "relay" },
      { source: "rollo", target: "srv-nancy", kind: "p2p" },
      { source: "butch", target: "srv-nancy", kind: "http" },
      // sluggo's own devices + the friends he hosts
      { source: "sluggo-phone", target: "srv-sluggo", kind: "relay" },
      { source: "sluggo-laptop", target: "srv-sluggo", kind: "p2p" },
      // sluggo's tablet reaches his laptop over the p2p http relay
      { source: "sluggo-phone", target: "sluggo-laptop", kind: "relay" },
      // nancy's android also peers direct p2p with sluggo's laptop
      { source: "nancy-android", target: "sluggo-laptop", kind: "p2p" },
      { source: "irma", target: "srv-sluggo", kind: "p2p" },
      { source: "oona", target: "srv-sluggo", kind: "relay" },
      { source: "phil", target: "srv-sluggo", kind: "http" },
      // several people have accounts on more than one server — guests aren't
      // locked to a single host.
      { source: "fritzi", target: "srv-nancy", kind: "p2p" },
      { source: "rollo", target: "srv-you", kind: "p2p" },
      { source: "irma", target: "srv-nancy", kind: "http" },
      { source: "phil", target: "srv-you", kind: "relay" },
      { source: "oona", target: "srv-nancy", kind: "p2p" },
      { source: "butch", target: "srv-sluggo", kind: "p2p" },
      // your own devices. your phone reaches every server you have an account
      // on through the p2p http relay; your laptop connects direct p2p.
      { source: "you-phone", target: "srv-you", kind: "relay" },
      { source: "you-phone", target: "srv-nancy", kind: "relay" },
      { source: "you-phone", target: "srv-sluggo", kind: "relay" },
      { source: "you-laptop", target: "srv-you", kind: "p2p" },
      // nancy's android peers direct p2p with your laptop too
      { source: "nancy-android", target: "you-laptop", kind: "p2p" },
      // your phone reaches your laptop over the relay
      { source: "you-phone", target: "you-laptop", kind: "relay" },
    ];

    const wrap = document.createElement("div");
    wrap.className = "sw-graph-wrap";
    c.appendChild(wrap);

    const W = Math.max(320, Math.min(820, c.clientWidth || 700));
    const H = 540;
    const svg = d3.select(wrap).append("svg")
      .attr("class", "sw-graph")
      .attr("viewBox", `0 0 ${W} ${H}`)
      .attr("preserveAspectRatio", "xMidYMid meet");

    // each edge is colored by the person it originates from; the dash pattern
    // shows the transport (solid p2p, dashed http, dotted relay).
    const personById = new Map(nodes.map((n) => [n.id, n.person]));
    const linkSel = svg.append("g").selectAll("line").data(links).join("line")
      .attr("class", (d) => `sw-g-link ${d.kind}`)
      .style("stroke", (d) => {
        if (d.kind === "mesh") return null;
        const sid = typeof d.source === "object" ? (d.source as any).id : d.source;
        return PERSON_COLOR[personById.get(sid) || ""] || null;
      });

    const nodeSel = svg.append("g").selectAll("g").data(nodes).join("g")
      .attr("class", "sw-g-node");
    nodeSel.each(function (d) {
      const g = d3.select(this);
      const fill = PERSON_COLOR[d.person] || GROUP[d.group];
      if (d.server) {
        g.append("polygon").attr("class", "sw-g-shape")
          .attr("points", freqholePoints(40))
          .attr("fill", fill).attr("stroke", GROUP[d.group])
          .attr("stroke-linejoin", "round");
      } else {
        g.append("circle").attr("class", "sw-g-shape").attr("r", 18)
          .attr("fill", fill).attr("stroke", GROUP[d.group]);
      }
    });
    nodeSel.append("g").attr("class", "sw-g-ico")
      .attr("transform", (d) => `translate(${d.server ? -11 : -10},${d.server ? -17 : -10})`)
      .html((d) => `<svg width="${d.server ? 16 : 20}" height="${d.server ? 16 : 20}" viewBox="0 0 24 24">${ICONS[d.icon] || ""}</svg>`);
    // each label gets a rounded pill behind it for legibility over edges/nodes.
    // the svg isn't attached to the document yet when this runs, so getBBox()
    // would return zeros - estimate the box from the label length instead.
    nodeSel.each(function (d) {
      const g = d3.select(this);
      const lg = g.append("g").attr("class", "sw-g-label");
      const ly = d.server ? 48 : 33;
      const w = d.label.length * 6.1 + 12; // ~6px per char at 11px + padding
      const h = 16;
      lg.append("rect")
        .attr("class", "sw-g-label-bg")
        .attr("x", -w / 2).attr("y", ly - 11)
        .attr("width", w).attr("height", h)
        .attr("rx", h / 2);
      lg.append("text").attr("y", ly).text(d.label);
    });

    const sim = d3.forceSimulation<GNode>(nodes)
      .force("link", d3.forceLink<GNode, GLink>(links).id((d) => d.id)
        .distance((d: any) => {
          // keep each person's own devices clumped tight to their server, but
          // stretch cross-person (guest) links long so the clusters fan out
          // into any free space.
          const sid = typeof d.source === "object" ? d.source.id : d.source;
          const tid = typeof d.target === "object" ? d.target.id : d.target;
          const same = personById.get(sid) === personById.get(tid);
          return same ? 64 : 175;
        })
        .strength((d: any) => {
          const sid = typeof d.source === "object" ? d.source.id : d.source;
          const tid = typeof d.target === "object" ? d.target.id : d.target;
          const same = personById.get(sid) === personById.get(tid);
          return same ? 0.85 : 0.18;
        }))
      .force("charge", d3.forceManyBody().strength(-720))
      .force("center", d3.forceCenter(W / 2, H / 2 - 6))
      .force("collide", d3.forceCollide(46))
      // gently anchor your own nodes toward the top-left so everyone else fans
      // out from there; weak strength keeps the overall spread intact.
      .force("anchorX", d3.forceX<GNode>((d) => (d.person === "you" ? W * 0.2 : W / 2)).strength((d) => (d.person === "you" ? 0.25 : 0.02)))
      .force("anchorY", d3.forceY<GNode>((d) => (d.person === "you" ? H * 0.2 : H / 2)).strength((d) => (d.person === "you" ? 0.25 : 0.02)))
      .on("tick", () => {
        nodes.forEach((n) => {
          n.x = Math.max(34, Math.min(W - 34, n.x!));
          // labels sit below the node center (server label ~53px down), so keep
          // a bigger bottom margin to avoid clipping them on the lower edge.
          n.y = Math.max(28, Math.min(H - 62, n.y!));
        });
        linkSel
          .attr("x1", (d: any) => d.source.x).attr("y1", (d: any) => d.source.y)
          .attr("x2", (d: any) => d.target.x).attr("y2", (d: any) => d.target.y);
        nodeSel.attr("transform", (d) => `translate(${d.x},${d.y})`);
      });

    const drag = d3.drag<SVGGElement, GNode>()
      .on("start", (event, d) => { if (!event.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
      .on("drag", (event, d) => { d.fx = event.x; d.fy = event.y; })
      .on("end", (event, d) => { if (!event.active) sim.alphaTarget(0); d.fx = undefined; d.fy = undefined; });
    nodeSel.call(drag as any);

    // hover highlight: the graph sits muted by default, and hovering a node
    // brings it, its neighbors, and their edges up to full brightness while
    // dimming everything else.
    const linkId = (v: any) => (typeof v === "object" ? v.id : v);
    const neighbors = new Map<string, Set<string>>(nodes.map((n) => [n.id, new Set<string>([n.id])]));
    links.forEach((l) => {
      const s = linkId(l.source), t = linkId(l.target);
      neighbors.get(s)?.add(t);
      neighbors.get(t)?.add(s);
    });
    function highlight(id: string | null) {
      if (!id) {
        nodeSel.classed("dim", false).classed("hot", false);
        linkSel.classed("dim", false).classed("hot", false);
        return;
      }
      const near = neighbors.get(id) || new Set([id]);
      nodeSel.classed("hot", (d) => near.has(d.id)).classed("dim", (d) => !near.has(d.id));
      linkSel
        .classed("hot", (d: any) => linkId(d.source) === id || linkId(d.target) === id)
        .classed("dim", (d: any) => !(linkId(d.source) === id || linkId(d.target) === id));
    }
    nodeSel
      .on("mouseenter", (_e, d) => highlight(d.id))
      .on("mouseleave", () => highlight(null));

    const legend = document.createElement("div");
    legend.className = "sw-legend";
    legend.innerHTML =
      `<span><i class="p2p"></i> p2p (direct)</span>` +
      `<span><i class="http"></i> http (same network / proxy)</span>` +
      `<span><i class="relay"></i> p2p http relay (phones + web apps)</span>` +
      `<span class="sw-legend-sep"></span>` +
      `<span><i class="ring you"></i> you</span>` +
      `<span><i class="ring family"></i> family</span>` +
      `<span><i class="ring friend"></i> friend</span>`;
    wrap.appendChild(legend);
  }

  // ===== stage 4: library management ======================================
  function renderLibrary(c: HTMLElement) {
    stageHeader(c, "manage + enrich your library", "grow your catalog, let trusted users add music, and clean up metadata with free enrichment sources.");

    const holder = document.createElement("div");
    holder.style.marginTop = "1rem";
    c.appendChild(holder);

    const cards: Card[] = [
      { icon: "eyes", title: "scan directories",
        body: "add more folders of music at any time. rescan existing folders to catch new or deleted files. you can tag all the music in a directory so it's easier to find later.",
        link: { href: "/guides/scanning/", text: "scanning your library" } },
      { icon: "share", title: "users can add music",
        body: "you or other users with a member or admin role can upload + add new music, create playlists, and edit metadata; viewer roles can browse and add things to their favorite list.",
        link: { href: "/concepts/user-roles/", text: "user roles" } },
      { icon: "edit", title: "edit metadata", badge: "one-off",
        body: "open an album → edit album to fix a single release: titles, dates, art images, taxons, track + disc order, and a manual musicbrainz lookup.",
        link: { href: "/guides/metadata-enrichment/", text: "metadata enrichment" } },
      { icon: "table", title: "albums table bulk edit", badge: "whole library",
        body: "the albums table view has bulk tools for reviewing + enriching many albums at once - better for a full library pass.",
        link: { href: "/guides/metadata-enrichment/", text: "bulk enrichment" } },
      { icon: "sparkle", title: "enrichment sources",
        body: "musicbrainz (canonical metadata + cover art), last.fm (related artists, bios, and tags note: you need to add an api key to freqhole-config.toml), and theaudiodb (artist imagery and tags).",
        link: { href: "/guides/metadata-enrichment/", text: "set up enrichment" } },
    ];
    cardGrid(holder, cards);
  }

  // kick off once everything above is declared and initialized.
  if (root) init(root);
</script>
