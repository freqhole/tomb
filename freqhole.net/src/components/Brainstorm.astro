        ] },
        { id: "ios", label: "iphone / ios", icon: "apple", kids: [
          { id: "ios/web", label: "web app", sub: "spume", icon: "web", leaf: web },
        ] },
        { id: "other", label: "everything else", sub: "other os", icon: "mobile", kids: [
          { id: "other/web", label: "web app", sub: "spume", icon: "web", leaf: web },
        ] },
      ] },
      { id: "raspi", label: "raspberry pi", sub: "linux / arm", icon: "raspi", kids: [
        { id: "raspi/gui", label: "gui app", sub: "charnel", icon: "gui", kids: [
          { id: "raspi/gui/deb", label: ".deb", sub: "raspberry pi os", icon: "download", leaf: charnel("charnel-linux-arm-deb", ".deb") },
          { id: "raspi/gui/rpm", label: ".rpm", sub: "fedora / red hat", icon: "download", leaf: charnel("charnel-linux-arm-rpm", ".rpm") },
          { id: "raspi/gui/flatpak", label: ".flatpak", sub: "arch / immutable", icon: "download", leaf: charnel("charnel-linux-arm-flatpak", ".flatpak") },
        ] },
        { id: "raspi/cli", label: "command line", sub: "rathole", icon: "cli", kids: [
          { id: "raspi/cli/arm64", label: "arm64", sub: "pi 4 / 5", icon: "chip", leaf: rathole("cli-linux-arm64") },
