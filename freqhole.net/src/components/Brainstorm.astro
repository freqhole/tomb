            { id: "mac/cli/x86", label: "x86_64", sub: "binary", icon: "chip", leaf: rathole("cli-mac-intel") },
          ] },
        ] },
        { id: "windows", label: "windows", icon: "windows", kids: [
          { id: "windows/web", label: "web app", sub: "spume", icon: "web", leaf: web },
        ] },
        { id: "linux", label: "linux", icon: "linux", kids: [
          { id: "linux/gui", label: "gui app", sub: "charnel", icon: "gui", kids: [
            { id: "linux/gui/x86", label: "x86_64", sub: "intel / amd", icon: "chip", kids: [
              { id: "linux/gui/x86/deb", label: ".deb", sub: "debian / ubuntu", icon: "download", leaf: charnel("charnel-linux-x86-deb", ".deb") },
              { id: "linux/gui/x86/rpm", label: ".rpm", sub: "fedora / red hat", icon: "download", leaf: charnel("charnel-linux-x86-rpm", ".rpm") },
              { id: "linux/gui/x86/flatpak", label: ".flatpak", sub: "arch / immutable", icon: "download", leaf: charnel("charnel-linux-x86-flatpak", ".flatpak") },
            ] },
            { id: "linux/gui/arm", label: "arm64", sub: "aarch64", icon: "chip", kids: [
              { id: "linux/gui/arm/deb", label: ".deb", sub: "debian / ubuntu", icon: "download", leaf: charnel("charnel-linux-arm-deb", ".deb") },
              { id: "linux/gui/arm/rpm", label: ".rpm", sub: "fedora / red hat", icon: "download", leaf: charnel("charnel-linux-arm-rpm", ".rpm") },
              { id: "linux/gui/arm/flatpak", label: ".flatpak", sub: "arch / immutable", icon: "download", leaf: charnel("charnel-linux-arm-flatpak", ".flatpak") },
            ] },
          ] },
          { id: "linux/cli", label: "command line", sub: "rathole", icon: "cli", kids: [
            { id: "linux/cli/x86", label: "x86_64", sub: "binary", icon: "chip", leaf: rathole("cli-linux-x86") },
            { id: "linux/cli/arm", label: "arm64", sub: "binary", icon: "chip", leaf: rathole("cli-linux-arm64") },
          ] },
        ] },
      ] },
      { id: "mobile", label: "mobile", sub: "phone / tablet", icon: "mobile", kids: [
        { id: "android", label: "android", icon: "android", kids: [
          { id: "android/arm64", label: "arm64", sub: "default .apk", icon: "chip", leaf: charnel("charnel-android-arm64", ".apk") },
