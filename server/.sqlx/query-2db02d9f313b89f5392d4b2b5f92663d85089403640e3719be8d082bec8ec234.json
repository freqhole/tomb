  "query": "\n        SELECT\n            mb.id as blob_id,\n            s.id as \"song_id?\",\n            mb.metadata\n        FROM media_blobs mb\n        LEFT JOIN songs s ON s.media_blob_id = mb.id\n        WHERE mb.sha256 = $1\n        LIMIT 1\n        ",
