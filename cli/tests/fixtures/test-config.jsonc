{
  "app": {
    "name": "GRIMOIRE TEST",
    "version": "0.1.0",
    "description": "TEST CONFIGURATION",
    "id": "test-instance"
  },
  "data_dir": "../data",
  "database": {
    "filename": "test.db",
    "auto_run_migrations": true
  },
  "media": {
    "max_fs_file_size": 104857600,
    "supported_audio_formats": ["mp3", "flac", "m4a", "ogg", "wav", "opus"],
    "downloads": {
      "enabled": false,
      "ytdlp_command": "yt-dlp"
    },
    "genres": []
  },
  "musicbrainz": {
    "enabled": false
  },
  "logging": {
    "level": "warn"
  }
}
