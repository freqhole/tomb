{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                me.media_blob_id,\n                me.event_type,\n                me.event_data,\n                me.domain_type,\n                me.domain_id,\n                me.session_id,\n                me.created_at,\n                s.id as \"song_id: Option<Uuid>\",\n                s.title as \"title: Option<String>\",\n                s.artist,\n                s.album,\n                s.album_artist,\n                s.track_number,\n                s.disc_number,\n                EXTRACT(epoch FROM s.duration)::integer as duration_seconds,\n                s.genre,\n                s.year,\n                s.bpm,\n                s.key_signature,\n                s.thumbnail_blob_id,\n                s.waveform_blob_id,\n                s.created_at as \"song_created_at: Option<OffsetDateTime>\"\n            FROM media_events me\n            LEFT JOIN songs s ON s.media_blob_id = me.media_blob_id\n            WHERE me.user_id = $1\n            ORDER BY me.created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
