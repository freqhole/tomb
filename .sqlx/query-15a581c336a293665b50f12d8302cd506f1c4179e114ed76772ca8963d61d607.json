  "query": "\n            SELECT id, local_path, data, mime, size, metadata\n            FROM media_blobs\n            WHERE parent_blob_id = $1 AND deleted_at IS NULL\n            AND blob_type IN ('thumbnail', 'waveform', 'preview')\n            ORDER BY created_at DESC\n            ",
