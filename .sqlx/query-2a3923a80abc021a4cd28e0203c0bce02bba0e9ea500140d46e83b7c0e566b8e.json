  "query": "\n            SELECT id, metadata, status, job_type, scheduled_at, retry_count, created_at, updated_at\n            FROM thumbnail_jobs\n            WHERE status = $1\n            AND (job_type LIKE '%thumbnail%' OR job_type LIKE '%waveform%')\n            ORDER BY scheduled_at ASC\n            LIMIT $2\n            ",
