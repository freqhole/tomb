{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, metadata, state, task_type, scheduled_at, retries, created_at, updated_at\n            FROM thumbnail_jobs\n            WHERE state = $1\n            AND (task_type LIKE '%thumbnail%' OR task_type LIKE '%waveform%')\n            ORDER BY updated_at DESC\n            LIMIT $2\n            ",
