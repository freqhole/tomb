{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "freqhole",
  "version": "0.1.11",
  "identifier": "net.freqhole.charnel",
  "build": {
    "beforeDevCommand": "npm run dev:all",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:wizard && cd ../spume && VITE_CHARNEL_MODE=true npm run build && cp -r ../charnel/dist/wizard dist/ && cp ../charnel/public/about.html dist/",
    "frontendDist": "../../spume/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1", "ffmpeg"],
        "desktopTemplate": "freqhole.desktop"
      },
      "rpm": {
        "depends": ["libayatana-appindicator-gtk3"],
        "desktopTemplate": "freqhole.desktop"
      }
    }
  }
}
