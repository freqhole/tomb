{
  "name": "skein",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:deploy": "vite build --config vite.standalone.config.ts",
    "build:cloudflare": "VITE_SKEIN_BASE=/skein/ vite build --config vite.standalone.config.ts && mv dist/skein.html dist/index.html",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:report": "open coverage/html/index.html",
    "lint": "eslint src widgets --ext .ts",
    "lint:fix": "eslint src widgets --ext .ts --fix",
    "lint:circular": "npx madge --circular --extensions ts src/ widgets/",
    "ts-prune": "ts-prune",
    "check": "npm run typecheck && npm run lint && npm run lint:circular && npm run test:all"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.5.5",
    "@automerge/automerge-repo-network-broadcastchannel": "^2.5.5",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.5",
    "@pixi/ui": "^2.3.2",
    "midden": "file:../midden/pkg",
    "pixi.js": "^8.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.2"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "printWidth": 100,
    "tabWidth": 2
  }
}
