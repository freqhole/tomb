# FreqHole Music Admin Development Configuration

# API Base URL for the backend server
# In development, this is typically your local server
# In production, this should be omitted to use the current origin
VITE_API_BASE_URL=http://localhost:8080

# Authentication token (optional)
# If your API requires authentication, set this
# VITE_AUTH_TOKEN=your_jwt_token_here

# Debug mode (optional)
# Set to true to enable additional logging
# VITE_DEBUG=true

# Server host configuration (for API server, not Vite)
# These are used if you need to configure CORS or allowed hosts
# VITE_API_HOST=localhost
# VITE_API_PORT=8080

# Development server configuration (overrides vite.config.ts)
# VITE_DEV_PORT=3003
# VITE_DEV_HOST=0.0.0.0

# Theme configuration
# VITE_DEFAULT_THEME=dark

# Example for different environments:
# Development: VITE_API_BASE_URL=http://localhost:8080
# Staging: VITE_API_BASE_URL=https://api-staging.freqhole.com
# Production: (omit VITE_API_BASE_URL to use current origin)
