{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "freqhole-app",
  "version": "0.1.1",
  "identifier": "com.freqhole.freqhole-app",
  "build": {
    "beforeDevCommand": "npm run dev:all",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:wizard && cd ../spume && VITE_TAURI_MODE=true npm run build",
    "frontendDist": "../../spume/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
